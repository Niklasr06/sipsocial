# SipSocial Backend Configuration
# Diese Datei nach `.env` kopieren und Werte eintragen. Niemals committen.

# Postgres-Verbindung (z. B. Neon-Connection-String).
# Beispiel Neon:  postgresql://user:pwd@ep-xxxxx.eu-central-1.aws.neon.tech/sipsocial?sslmode=require
# Lokal (ohne SSL): postgresql://user:pwd@localhost:5432/sipsocial?sslmode=disable
# Leer lassen → Mock-Only-Modus (kein DB-Zugriff, App läuft trotzdem).
DATABASE_URL=

# Google Places API — optional. Ohne Key werden Mock-Cafés genutzt.
GOOGLE_MAPS_API_KEY=

# Symmetrischer Schlüssel für Chat-Verschlüsselung (Fernet, Base64-codiert).
# Generieren mit:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
CHAT_ENCRYPTION_KEY=

# JWT-Secret für Session-Tokens. Generieren mit:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET=
JWT_EXPIRES_HOURS=168

# Erlaubte CORS-Origins für den Expo-Dev-Server.
BACKEND_CORS_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006,http://localhost:19000
