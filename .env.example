# SipSocial Frontend Configuration
# Copy this file to `.env` and adjust as needed.

# Base URL of the FastAPI backend. Leave empty to disable backend calls
# and use the bundled local mock data exclusively.
EXPO_PUBLIC_API_URL=http://localhost:8000

# Optional — only required if you want the map to render Google's tiles.
# The app works without a key (using the offline-style fallback view).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
